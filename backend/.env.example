# Backend Environment Variables
# Copy to .env and fill in values

MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/sprouted?retryWrites=true&w=majority
# Or local: mongodb://localhost:27017/sprouted

JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-for-prod

# Optional OpenAI
OPENAI_API_KEY=sk-...

# Vercel deploys auto from project env
